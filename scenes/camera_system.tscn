[sub_resource type="GDScript" id="GDScript_hcjyi"]
script/source = "extends Node2D

@export var base_speed: float = 300.0
@export var max_speed: float = 1000.0
@export var min_speed: float = 300.0

# Acceleration/Deceleration weights (Tweak these for \"feel\")
@export var accel_weight: float = 0.1   # Higher = faster ramp up
@export var decel_weight: float = 0.5   # Higher = faster decline (as requested)

var current_scroll_speed: float = 150.0

@onready var camera = $Camera2D
@onready var edge_detector = $LeftEdgeDetector
@onready var copter = get_tree().current_scene.get_node(\"PlayerPair/Copter\") # Update path to your drone

signal player_fell_behind

func _ready():
	edge_detector.body_entered.connect(_on_body_entered)
	current_scroll_speed = base_speed

func _physics_process(delta):
	if not copter: return

	# 1. Calculate player's position relative to the camera center (0 to 1 range)
	# viewport_width / 2 is the center. 
	var viewport_width = get_viewport_rect().size.x
	var player_screen_pos = camera.get_canvas_transform() * copter.global_position
	var relative_x = player_screen_pos.x / viewport_width # 0.0 (left) to 1.0 (right)

	# 2. Determine Target Speed based on X position
	var target_speed = base_speed

	if relative_x > 0.5: # Last 1/3 of the screen
		target_speed = max_speed
		# Smoothly move current speed toward max
		current_scroll_speed = lerp(current_scroll_speed, target_speed, accel_weight * delta)
	
	elif relative_x < 0.5: # First 1/3 of the screen
		target_speed = min_speed
		# Decline FASTER (using decel_weight)
		current_scroll_speed = lerp(current_scroll_speed, target_speed, decel_weight * delta)

	# 3. Move the system
	position.x += current_scroll_speed * delta

func _on_body_entered(body):
	if body.name == \"Copter\":
		player_fell_behind.emit()
"

